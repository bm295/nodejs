@model DashboardViewModel

<section class="kpi-grid">
    <article class="kpi-card"><h2>Menu Items</h2><p>@Model.MenuItemsCount</p></article>
    <article class="kpi-card"><h2>Available</h2><p>@Model.AvailableMenuItemsCount</p></article>
    <article class="kpi-card"><h2>Inventory SKUs</h2><p>@Model.InventoryItemsCount</p></article>
    <article class="kpi-card warning"><h2>Low Stock</h2><p>@Model.LowStockItemsCount</p></article>
    <article class="kpi-card"><h2>Orders Today</h2><p>@Model.OrdersTodayCount</p></article>
    <article class="kpi-card success"><h2>Revenue Today</h2><p>$@Model.RevenueToday</p></article>
</section>

<section class="panel-grid">
    <article class="panel">
        <h3>Low Stock Alerts</h3>
        <ul>
            @foreach (var item in Model.LowStockItems)
            {
                <li>@item.Name: @item.QuantityInStock @item.Unit (Reorder @item.ReorderLevel)</li>
            }
        </ul>
    </article>

    <article class="panel">
        <h3>Recent Orders</h3>
        <ul>
            @foreach (var order in Model.RecentOrders)
            {
                <li>
                    #@order.Id - @order.OrderedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm") - $@order.Total
                </li>
            }
        </ul>
    </article>
</section>
